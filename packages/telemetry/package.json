{
  "name": "@typespec/telemetry",
  "version": "0.1.0",
  "author": "Microsoft",
  "description": "Define telemetry event and metrics in TypeSpec",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@alloy-js/core": "0.6.0",
    "@alloy-js/typescript": "0.6.0",
    "@typespec/compiler": "workspace:^",
    "@typespec/emitter-framework": "workspace:^"
  },
  "devDependencies": {
    "@alloy-js/babel-plugin": "0.2.0",
    "@babel/cli": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@typespec/tspd": "workspace:^",
    "@types/node": "^20.14.12",
    "concurrently": "^8.2.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "scripts": {
    "build-src": "babel src -d dist/src --extensions .ts,.tsx",
    "build-tsc": "tsc",
    "build": "pnpm gen-extern-signature && pnpm build-tsc && pnpm build-src",
    "clean": "rimraf dist/ .temp/",
    "gen-extern-signature": "tspd --enable-experimental gen-extern-signature .",
    "test": "vitest run",
    "test:watch": "vitest -w",
    "watch-src": "babel src -d dist/src --extensions '.ts,.tsx' --watch",
    "watch-check": "tsc --watch",
    "watch": "concurrently --kill-others \"pnpm watch-check\" \"pnpm watch-src\""
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "typespec": "./lib/main.tsp"
    },
    "./stc": {
      "import": "./dist/src/stc.js"
    }
  }
}
