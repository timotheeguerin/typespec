{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "jsxImportSource": "@alloy-js/core",
    "verbatimModuleSyntax": true,
    "emitDeclarationOnly": true,
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "generated-defs"],
  "exclude": ["node_modules", "dist", "test/e2e/generated/**/*.ts"]
}
